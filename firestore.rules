rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function admin() { return signedIn() && request.auth.token.admin == true; }

    match /products/{productId} {
      allow read: if true;
      allow write: if admin();
    }
    match /orders/{orderId} {
      allow read: if admin() || (signedIn() && resource.data.buyerId == request.auth.uid);
      // Orders and stock are created atomically by the trusted Cloud Function.
      allow create, update, delete: if admin();
    }
    match /notifications/{notificationId} {
      allow read: if admin() || (signedIn() && resource.data.buyerId == request.auth.uid);
      allow update: if signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if admin();
    }
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
